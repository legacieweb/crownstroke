  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist-server",
    "skipLibCheck": true,
    "lib": ["ES2022"]
  },
  "include": ["server.ts"]
}