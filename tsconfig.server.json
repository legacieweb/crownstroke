{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist-server",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "server.ts",
    "src/db/schema.ts"
  ]
}
